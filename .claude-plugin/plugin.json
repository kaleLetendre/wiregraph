{
  "name": "wiregraph",
  "description": "Cross-compartment call/association graph in an embedded SQLite file (no daemon, no JVM), exposed to Claude as MCP tools. Index a project once; navigate/audit/refactor code reading ~half the file bytes a grep-and-read would. Project-scoped, balanced auto-update, self-refresh via update_graph.",
  "author": { "name": "Kale Letendre", "email": "kaleletendre@gmail.com" },
  "commands": [
    "./commands/wiregraph-init.md",
    "./commands/wiregraph-update.md",
    "./commands/wiregraph-rebuild.md",
    "./commands/wiregraph-status.md",
    "./commands/wiregraph-stats.md",
    "./commands/wiregraph-stats-local.md",
    "./commands/wiregraph-posture.md",
    "./commands/wiregraph-contracts.md",
    "./commands/wiregraph-visualize.md",
    "./commands/wiregraph-linearize.md",
    "./commands/wiregraph-link.md",
    "./commands/wiregraph-unlink.md",
    "./commands/wiregraph-list.md",
    "./commands/wiregraph-teardown.md",
    "./commands/wiregraph-remove.md",
    "./commands/wiregraph-build.md",
    "./commands/wg-init.md",
    "./commands/wg-update.md",
    "./commands/wg-rebuild.md",
    "./commands/wg-status.md",
    "./commands/wg-stats.md",
    "./commands/wg-stats-local.md",
    "./commands/wg-posture.md",
    "./commands/wg-contracts.md",
    "./commands/wg-visualize.md",
    "./commands/wg-linearize.md",
    "./commands/wg-link.md",
    "./commands/wg-unlink.md",
    "./commands/wg-list.md",
    "./commands/wg-teardown.md",
    "./commands/wg-remove.md",
    "./commands/wg-build.md"
  ],
  "mcpServers": {
    "wiregraph": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/src/mcp/server.js"]
    }
  }
}
