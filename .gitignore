# This branch does NOT vendor dependencies — node_modules is gitignored. Install
# them with `npm install` (the /codegraph-init flow runs it for you). The trade-off
# vs. the default branch is documented in the README ("Dependencies"). package-lock.json
# stays committed so installs are reproducible.
node_modules/

# Build artifacts / exports (generated graph + visualizations embed source symbol
# names, never committed). Anchored to the repo root so they can't exclude
# matching files inside the vendored node_modules.
/out/
/*.db
/*.db-wal
/*.db-shm
/*.db.lock
/codegraph-*.html
/codegraph*.gexf
/npm-debug.log*
.codegraph/
