# tree-sitter-typescript declares a peerOptional tree-sitter ^0.21, which conflicts
# with the tree-sitter 0.22 the grammars are actually built against. The pin is
# deliberate (see .gitignore note on vendoring node_modules); accept the mismatch
# so a bare `npm install` works without the --legacy-peer-deps flag.
legacy-peer-deps=true
